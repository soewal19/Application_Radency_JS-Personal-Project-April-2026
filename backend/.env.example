# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (for Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventhub?schema=public

# Legacy env vars (for backward compatibility)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=eventhub

# JWT — REQUIRED! Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters. Never use default values in production.
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS — whitelist of allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenAI API (optional) for AI assistant; leave empty to use stubbed responses during local testing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq API (alternative for faster/free inference)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative models: llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it

