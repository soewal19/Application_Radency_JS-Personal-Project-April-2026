# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (for Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventhub?schema=public

# Legacy env vars (for backward compatibility)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=eventhub

# JWT
JWT_SECRET=super-secret-jwt-key-for-local-dev-eventhub-app

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80
