# Server
PORT=3000
NODE_ENV=development

# SQLite (for local development)
DATABASE_URL=file:./prisma/dev.db

# Legacy env vars (for backward compatibility)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=eventhub

# JWT
JWT_SECRET=super-secret-jwt-key-for-local-dev-eventhub-app

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000,http://localhost:80,https://application-frontend-fjji.onrender.com,https://application-backend-54iw.onrender.com

# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
